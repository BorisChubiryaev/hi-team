// Prisma schema — hi-team weekly reports
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Пользователи (вход по email + паролю, JWT-сессии Auth.js)
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String? // bcrypt; null = пароль ещё не задан (первый вход)
  image        String?
  createdAt    DateTime @default(now())

  reports Report[]
}

// ---------------------------------------------------------------------------
// Domain: weekly reports
// ---------------------------------------------------------------------------

enum ProjectStatus {
  ACTIVE
  PAUSED
  DONE
}

// Проект/направление как сущность: статус, история по неделям, AI-статус.
model Project {
  id             String        @id @default(cuid())
  name           String        @unique
  status         ProjectStatus @default(ACTIVE)
  aiSummary      String?       @db.Text // последняя AI-сводка по проекту
  aiSummaryModel String?
  aiSummaryAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  entries ReportProject[]
}

model Week {
  id        String   @id @default(cuid())
  label     String // напр. «15–19 июня»
  startDate DateTime @unique @db.Date
  endDate   DateTime @db.Date

  reports Report[]
  summary Summary?

  @@index([startDate])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  weekId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  week     Week            @relation(fields: [weekId], references: [id], onDelete: Cascade)
  projects ReportProject[]

  @@unique([userId, weekId])
}

model ReportProject {
  id        String  @id @default(cuid())
  reportId  String
  projectId String? // null только у строк до бэкфилла (prisma/backfill-projects.ts)
  name      String // название проекта/направления (снимок на момент отчёта)
  done      String  @default("") @db.Text // Сделано
  blockers  String  @default("") @db.Text // Блокеры
  plans     String  @default("") @db.Text // Планы
  order     Int     @default(0)

  report  Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([reportId])
  @@index([projectId])
}

// Сгенерированная ИИ сводка недели для руководителя
model Summary {
  id        String   @id @default(cuid())
  weekId    String   @unique
  content   String   @db.Text
  model     String
  createdAt DateTime @default(now())

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)
}
