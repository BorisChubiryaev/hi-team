# ---- База данных (Neon Postgres) ----
# Строка подключения из Neon (используйте pooled-вариант для serverless/Vercel).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth.js ----
# Сгенерируйте: npx auth secret
AUTH_SECRET=""

# Почты команды через запятую — только им разрешён вход. Пусто = вход всем.
# Каждый из этих адресов задаёт себе пароль при первом входе.
ALLOWED_EMAILS="boriksnote@gmail.com"

# ---- OpenRouter (AI-суммаризация) ----
# НОВЫЙ ключ (старый, присланный в чат, нужно отозвать). Только серверный.
OPENROUTER_API_KEY=""
# Бесплатная модель по умолчанию; можно поменять на любую с openrouter.ai/models
OPENROUTER_MODEL="deepseek/deepseek-chat-v3-0324:free"

# ---- Прочее ----
# Публичный URL приложения (для заголовков OpenRouter). На Vercel — адрес деплоя.
APP_URL="http://localhost:3000"

# ---- Cron (Vercel Cron: авто-сводка в пятницу, напоминания в четверг) ----
# Секрет для cron-роутов. На Vercel задаётся автоматически при наличии crons,
# локально сгенерируйте любой длинный случайный: openssl rand -hex 32
CRON_SECRET=""

# ---- Уведомления (необязательно; без них cron просто не шлёт сообщения) ----
# Telegram-бот: токен от @BotFather и id чата/группы команды.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Либо/или webhook, принимающий POST {"text": "..."} (Slack, Mattermost и т.п.)
NOTIFY_WEBHOOK_URL=""
