# ---- База данных (Neon Postgres) ----
# Строка подключения из Neon (используйте pooled-вариант для serverless/Vercel).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth.js ----
# Сгенерируйте: npx auth secret
AUTH_SECRET=""

# Почты команды через запятую — только им разрешён вход. Пусто = вход всем.
# Каждый из этих адресов задаёт себе пароль при первом входе.
ALLOWED_EMAILS="boriksnote@gmail.com"

# ---- OpenRouter (AI-суммаризация) ----
# НОВЫЙ ключ (старый, присланный в чат, нужно отозвать). Только серверный.
OPENROUTER_API_KEY=""
# Модель по умолчанию; можно поменять на любую с openrouter.ai/models
OPENROUTER_MODEL="google/gemini-2.5-flash"
# Лимит длины ответа модели. Без него OpenRouter резервирует полное окно модели
# и возвращает 402, если на балансе не хватает кредитов. 2048 хватает для сводок.
OPENROUTER_MAX_TOKENS="2048"

# ---- Email (Resend: отправка AI-сводок на почту) ----
# Ключ из https://resend.com/api-keys. Пусто = кнопка «На почту» вернёт ошибку.
RESEND_API_KEY=""
# From-адрес на ПОДТВЕРЖДЁННОМ домене (для hi-team.com). Локальную часть можно любую,
# заводить почтовый ящик не нужно. Для быстрого теста без домена: onboarding@resend.dev
# (Resend шлёт только на почту владельца аккаунта).
EMAIL_FROM="hi-team <noreply@hi-team.com>"

# ---- Прочее ----
# Публичный URL приложения (для заголовков OpenRouter). На Vercel — адрес деплоя.
APP_URL="http://localhost:3000"

# ---- Cron (Vercel Cron: авто-сводка в пятницу, напоминания в четверг) ----
# Секрет для cron-роутов. На Vercel задаётся автоматически при наличии crons,
# локально сгенерируйте любой длинный случайный: openssl rand -hex 32
CRON_SECRET=""

# ---- Уведомления (необязательно; без них cron просто не шлёт сообщения) ----
# Telegram-бот: токен от @BotFather и id чата/группы команды.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Либо/или webhook, принимающий POST {"text": "..."} (Slack, Mattermost и т.п.)
NOTIFY_WEBHOOK_URL=""

# ---- Telegram-бот (напоминания + отправка отчёта из чата) ----
# Токен от @BotFather. Тот же токен использует и отправка уведомлений выше.
TELEGRAM_BOT_TOKEN=""
# Username бота без @ — для deep-link привязки аккаунта (t.me/<username>?start=…).
TELEGRAM_BOT_USERNAME="HiTeamB2CBot"
# Секрет проверки webhook: любой длинный случайный (openssl rand -hex 32).
# Его же Telegram присылает в заголовке X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=""
